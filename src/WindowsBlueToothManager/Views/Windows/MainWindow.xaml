<Window x:Class="WindowsBlueToothManager.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowsBlueToothManager"
        Width="960"
        Height="640"
        MinWidth="720"
        MinHeight="480"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F6F8FB">
        <Border Width="560"
                Padding="32"
                Background="White"
                BorderBrush="#D8DEE8"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="WindowsBlueToothManager"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#1E293B" />
                <TextBlock Margin="0,12,0,0"
                           Text="WPF project skeleton is ready."
                           FontSize="16"
                           Foreground="#475569" />
                <TextBlock Margin="0,24,0,0"
                           Text="Next feature will start after you confirm this project skeleton can build and run on Windows."
                           FontSize="14"
                           Foreground="#64748B"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
