<Window x:Class="WindowsBlueToothManager.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowsBlueToothManager"
        Width="1120"
        Height="720"
        MinWidth="900"
        MinHeight="560"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="SummaryPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D8DEE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="SecondaryTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderBrush" Value="#EDF2F7" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="#EDF2F7" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Background="#F3F6FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#D8DEE8"
                BorderThickness="0,0,0,1">
            <Menu Background="#FFFFFF"
                  MinHeight="40"
                  Padding="16,3">
                <MenuItem Header="{Binding SettingsMenuText}">
                    <MenuItem Header="{Binding LanguageMenuText}">
                        <MenuItem Header="{Binding ChineseLanguageText}"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsChineseLanguageSelected, Mode=OneWay}"
                                  Click="ChineseLanguageMenuItem_Click" />
                        <MenuItem Header="{Binding EnglishLanguageText}"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsEnglishLanguageSelected, Mode=OneWay}"
                                  Click="EnglishLanguageMenuItem_Click" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="{Binding DataSourceMenuText}">
                        <MenuItem Header="{Binding WindowsBluetoothSourceText}"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsWindowsBluetoothSourceSelected, Mode=OneWay}"
                                  Click="WindowsBluetoothSourceMenuItem_Click" />
                        <MenuItem Header="{Binding SimulatedSourceText}"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsSimulatedSourceSelected, Mode=OneWay}"
                                  Click="SimulatedSourceMenuItem_Click" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="{Binding RefreshFrequencyMenuText}">
                        <MenuItem Header="{Binding Refresh5SecondsText}"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsRefresh5SecondsSelected, Mode=OneWay}"
                                  Click="Refresh5SecondsMenuItem_Click" />
                        <MenuItem Header="{Binding Refresh10SecondsText}"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsRefresh10SecondsSelected, Mode=OneWay}"
                                  Click="Refresh10SecondsMenuItem_Click" />
                        <MenuItem Header="{Binding Refresh30SecondsText}"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsRefresh30SecondsSelected, Mode=OneWay}"
                                  Click="Refresh30SecondsMenuItem_Click" />
                        <MenuItem Header="{Binding Refresh1MinuteText}"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsRefresh1MinuteSelected, Mode=OneWay}"
                                  Click="Refresh1MinuteMenuItem_Click" />
                    </MenuItem>
                </MenuItem>
            </Menu>
        </Border>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#D8DEE8"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <DockPanel LastChildFill="True">
                <StackPanel>
                    <TextBlock Text="WindowsBlueToothManager"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="#0F172A" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource SecondaryTextStyle}"
                               Text="{Binding StatusText}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource SummaryPanelStyle}"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="{Binding ConnectedLabelText}"
                                   Style="{StaticResource SecondaryTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding ConnectedDeviceCount}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource SummaryPanelStyle}"
                        Margin="6,0,6,0">
                    <StackPanel>
                        <TextBlock Text="{Binding ShownAtBottomLabelText}"
                                   Style="{StaticResource SecondaryTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding OverlayDeviceCount}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource SummaryPanelStyle}"
                        Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding LowBatteryLabelText}"
                                   Style="{StaticResource SecondaryTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding LowBatteryDeviceCount}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="#B91C1C" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,20,0,0"
                    Background="#FFFFFF"
                    BorderBrush="#D8DEE8"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="18,16,18,14"
                               LastChildFill="True">
                        <TextBlock DockPanel.Dock="Right"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="{Binding LastRefreshText}" />
                        <StackPanel>
                            <TextBlock Text="{Binding DeviceListTitleText}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A" />
                            <TextBlock Margin="0,4,0,0"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="{Binding SummaryText}" />
                        </StackPanel>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Devices}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              IsReadOnly="False"
                              RowHeight="58"
                              BorderThickness="0"
                              Background="#FFFFFF"
                              HorizontalGridLinesBrush="#EDF2F7"
                              AlternatingRowBackground="#F8FAFC">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="DeviceColumn"
                                                Width="2.2*"
                                                Binding="{Binding Name}"
                                                IsReadOnly="True" />
                            <DataGridTextColumn x:Name="TypeColumn"
                                                Width="0.8*"
                                                Binding="{Binding DeviceTypeText}"
                                                IsReadOnly="True" />
                            <DataGridTemplateColumn x:Name="StatusColumn"
                                                    Width="1*"
                                                    IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ConnectionStatusText}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding ConnectionStatusBrush}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn x:Name="BatteryColumn"
                                                    Width="1.8*"
                                                    IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="50" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0"
                                                        VerticalAlignment="Center">
                                                <ProgressBar Minimum="0"
                                                             Maximum="100"
                                                             Height="8"
                                                             Value="{Binding BatteryProgressValue, Mode=OneWay}"
                                                             Foreground="{Binding BatteryProgressBrush}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding BatteryStateText}"
                                                           FontSize="12"
                                                           Foreground="#64748B" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding BatteryText}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Left"
                                                       Margin="10,0,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="#0F172A" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridCheckBoxColumn x:Name="BottomColumn"
                                                    Width="0.8*"
                                                    Binding="{Binding ShowInTaskbarOverlay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridCheckBoxColumn x:Name="TrayColumn"
                                                    Width="0.7*"
                                                    Binding="{Binding ShowInTray, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn x:Name="DisplayColumn"
                                                Width="1.1*"
                                                Binding="{Binding DisplayTargetText}"
                                                IsReadOnly="True" />
                            <DataGridTextColumn x:Name="UpdatedColumn"
                                                Width="0.9*"
                                                Binding="{Binding LastUpdatedText}"
                                                IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Background="#FFFFFF"
                BorderBrush="#D8DEE8"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <TextBlock Style="{StaticResource SecondaryTextStyle}"
                       Text="{Binding FooterText}" />
        </Border>
    </Grid>
</Window>
