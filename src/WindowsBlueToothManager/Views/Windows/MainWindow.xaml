<Window x:Class="WindowsBlueToothManager.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowsBlueToothManager"
        Width="1120"
        Height="720"
        MinWidth="900"
        MinHeight="560"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="SummaryPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D8DEE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="SecondaryTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Background="#F3F6FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#D8DEE8"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Content="Refresh"
                        Click="RefreshButton_Click" />
                <StackPanel>
                    <TextBlock Text="WindowsBlueToothManager"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="#0F172A" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource SecondaryTextStyle}"
                               Text="{Binding StatusText}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource SummaryPanelStyle}"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Connected"
                                   Style="{StaticResource SecondaryTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding ConnectedDeviceCount}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource SummaryPanelStyle}"
                        Margin="6,0,6,0">
                    <StackPanel>
                        <TextBlock Text="Shown at bottom"
                                   Style="{StaticResource SecondaryTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding OverlayDeviceCount}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource SummaryPanelStyle}"
                        Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Low battery"
                                   Style="{StaticResource SecondaryTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding LowBatteryDeviceCount}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="#B91C1C" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,20,0,0"
                    Background="#FFFFFF"
                    BorderBrush="#D8DEE8"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="18,16,18,14"
                               LastChildFill="True">
                        <TextBlock DockPanel.Dock="Right"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Text="{Binding LastRefreshText}" />
                        <StackPanel>
                            <TextBlock Text="Connected Bluetooth devices"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A" />
                            <TextBlock Margin="0,4,0,0"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       Text="{Binding SummaryText}" />
                        </StackPanel>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Devices}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              IsReadOnly="False"
                              RowHeight="58"
                              BorderThickness="0"
                              Background="#FFFFFF"
                              AlternatingRowBackground="#F8FAFC">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Device"
                                                Width="2.2*"
                                                Binding="{Binding Name}"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="Type"
                                                Width="0.8*"
                                                Binding="{Binding DeviceTypeText}"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="Status"
                                                Width="1*"
                                                Binding="{Binding ConnectionStatusText}"
                                                IsReadOnly="True" />
                            <DataGridTemplateColumn Header="Battery"
                                                    Width="1.8*"
                                                    IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="58" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0"
                                                        VerticalAlignment="Center">
                                                <ProgressBar Minimum="0"
                                                             Maximum="100"
                                                             Height="8"
                                                             Value="{Binding BatteryProgressValue}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding BatteryStateText}"
                                                           FontSize="12"
                                                           Foreground="#64748B" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding BatteryText}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       FontWeight="SemiBold"
                                                       Foreground="#0F172A" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridCheckBoxColumn Header="Bottom"
                                                    Width="0.8*"
                                                    Binding="{Binding ShowInTaskbarOverlay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridCheckBoxColumn Header="Tray"
                                                    Width="0.7*"
                                                    Binding="{Binding ShowInTray, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="Display"
                                                Width="1.1*"
                                                Binding="{Binding DisplayTargetText}"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="Updated"
                                                Width="0.9*"
                                                Binding="{Binding LastUpdatedText}"
                                                IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#D8DEE8"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <TextBlock Style="{StaticResource SecondaryTextStyle}"
                       Text="Simulated data mode. Real Bluetooth scanning will be connected in the next hardware integration phase." />
        </Border>
    </Grid>
</Window>
