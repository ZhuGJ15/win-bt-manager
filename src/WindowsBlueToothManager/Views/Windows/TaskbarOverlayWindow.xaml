<Window x:Class="WindowsBlueToothManager.Views.Windows.TaskbarOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="280"
        Height="40"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#20242B"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Border Background="#20242B"
            BorderBrush="#3A414C"
            BorderThickness="1"
            CornerRadius="6"
            Padding="6,4">
        <Grid>
            <TextBlock Text="{Binding TaskbarOverlayPlaceholderText}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#E5E7EB">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasTaskbarOverlayDevices}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ItemsControl ItemsSource="{Binding TaskbarOverlayDevices}"
                          Visibility="{Binding HasTaskbarOverlayDevices, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border MinWidth="58"
                                MaxWidth="92"
                                Height="28"
                                Margin="0,0,6,0"
                                Padding="6,3"
                                Background="#2B313A"
                                BorderBrush="#434B57"
                                BorderThickness="1"
                                CornerRadius="5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="4" />
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0"
                                           LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Right"
                                               Margin="5,0,0,0"
                                               Text="{Binding BatteryText}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding BatteryProgressBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="10"
                                               Foreground="#F8FAFC"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                                <ProgressBar Grid.Row="1"
                                             Height="3"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding BatteryProgressValue, Mode=OneWay}"
                                             Foreground="{Binding BatteryProgressBrush}"
                                             Background="#111827" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</Window>
