<Window x:Class="WindowsBlueToothManager.Views.Windows.TaskbarOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="54"
        Height="38"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid x:Name="OverlayRoot"
          Background="Transparent"
          ClipToBounds="True">
        <Border x:Name="PlaceholderTile"
                Width="50"
                Height="36"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="3,1"
                Background="#2B313A"
                BorderBrush="#434B57"
                BorderThickness="1"
                CornerRadius="5">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasTaskbarOverlayDevices}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding TaskbarOverlayPlaceholderText}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="10"
                       FontWeight="SemiBold"
                       LineHeight="11"
                       TextAlignment="Center"
                       Foreground="#E5E7EB" />
        </Border>

        <StackPanel x:Name="DeviceTilesPanel"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    ClipToBounds="True" />
    </Grid>
</Window>
