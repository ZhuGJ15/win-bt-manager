<Window x:Class="WindowsBlueToothManager.Views.Windows.TaskbarOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="54"
        Height="38"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Background="Transparent">
        <Border Width="50"
                Height="36"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="3,1"
                Background="#2B313A"
                BorderBrush="#434B57"
                BorderThickness="1"
                CornerRadius="5">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasTaskbarOverlayDevices}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding TaskbarOverlayPlaceholderText}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="10"
                       FontWeight="SemiBold"
                       LineHeight="11"
                       TextAlignment="Center"
                       Foreground="#E5E7EB" />
        </Border>

        <ItemsControl x:Name="OverlayItems"
                      ItemsSource="{Binding TaskbarOverlayDevices}"
                      Visibility="{Binding HasTaskbarOverlayDevices, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="50"
                            Height="36"
                            Margin="2,0"
                            Padding="3,1"
                            Background="#2B313A"
                            BorderBrush="#434B57"
                            BorderThickness="1"
                            CornerRadius="5">
                        <StackPanel VerticalAlignment="Center"
                                    ClipToBounds="True">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="8"
                                       FontWeight="SemiBold"
                                       Foreground="#F8FAFC"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       ClipToBounds="True" />
                            <TextBlock Margin="0,1,0,0"
                                       Text="{Binding BatteryText}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{Binding BatteryProgressBrush}"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
